# ───────────────────────────────────────────────────────────────
#  공모전 규정: 중앙회 제공 원본 데이터는 외부 공개 불가 → 절대 커밋 금지
# ───────────────────────────────────────────────────────────────
data/raw/*
!data/raw/.gitkeep
★중앙회 제공데이터/
*.xlsx
# 합성 샘플 xlsx도 추적 안 함 → 필요 시 scripts/make_sample_data.py 로 재생성

# 원본 PDF/HWP 양식 (배포 금지 자료)
*.hwp
*.pdf

# Python
.venv/
__pycache__/
*.py[cod]
.ipynb_checkpoints/

# OS
.DS_Store

# 루트 작업용 원본 노트북 (셀 출력에 원본 레코드 포함 → 비공개)
공모전파이썬.ipynb

# 대용량 산출물(원하면 공개 가능 — 기본은 figures만 추적)
outputs/tables/*.csv
